#!/usr/bin/env python3
"""Build an evidence-based explainer from a captured proof run."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
CURRICULUM = ROOT / "curriculum"
sys.path.insert(0, str(CURRICULUM))

from explainer import build_explainer  # noqa: E402
from learning_flow import lesson_config, load_manifest  # noqa: E402
from learning_state import state_backend  # noqa: E402
from study_server import DEFAULT_DATABASE  # noqa: E402


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("lesson_id")
    parser.add_argument("proof_artifact", type=Path)
    parser.add_argument("--database", type=Path, default=DEFAULT_DATABASE)
    parser.add_argument("--local", action="store_true", help="Use local SQLite even when remote sync is configured")
    args = parser.parse_args()
    store = state_backend(args.database, prefer_remote=not args.local)
    state = store.load(args.lesson_id)
    markdown_path, html_path = build_explainer(
        args.lesson_id,
        lesson_config(args.lesson_id, load_manifest()),
        state,
        args.proof_artifact,
    )
    evidence = dict(state["evidence"])
    evidence["explainer_path"] = str(html_path.relative_to(ROOT))
    payload = {key: state[key] for key in ("status", "responses", "plan", "reflection", "phase", "milestones")}
    payload.update({"evidence": evidence, "event_source": "build-explainer"})
    store.save(args.lesson_id, payload)
    print(markdown_path.relative_to(ROOT))
    print(html_path.relative_to(ROOT))


if __name__ == "__main__":
    main()
