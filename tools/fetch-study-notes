#!/usr/bin/env bash
set -euo pipefail

: "${STUDY_SITE_URL:?Set STUDY_SITE_URL to your Netlify site URL (for example, https://study.example.net).}"
: "${STUDY_ACCESS_TOKEN:?Set STUDY_ACCESS_TOKEN to your study sync token.}"

snapshot="${1:-curriculum/data/study.json}"
notes_directory="curriculum/data/study-notes"
temporary="${snapshot}.tmp"
mkdir -p "$(dirname "$snapshot")" "$notes_directory"

curl --fail --silent --show-error \
  -H "X-Study-Token: ${STUDY_ACCESS_TOKEN}" \
  "${STUDY_SITE_URL%/}/api/export" \
  -o "$temporary"

mv "$temporary" "$snapshot"
jq -e '.schema_version == 1 and (.lessons | type == "object")' "$snapshot" > /dev/null

lesson_ids="$(jq -r '.lessons | keys[]' "$snapshot")"
while IFS= read -r lesson_id; do
  [ -n "$lesson_id" ] || continue
  case "$lesson_id" in
    [0-9][0-9][0-9][0-9]-[a-z0-9-]*) ;;
    *) echo "Unexpected lesson id in study export: $lesson_id" >&2; exit 1 ;;
  esac
  jq --arg lesson_id "$lesson_id" '.lessons[$lesson_id]' "$snapshot" > "$notes_directory/$lesson_id.json.tmp"
  mv "$notes_directory/$lesson_id.json.tmp" "$notes_directory/$lesson_id.json"
done <<EOF
$lesson_ids
EOF

# This directory is generated by this script. Remove only lesson files that
# no longer exist in the canonical remote record, so agents cannot read stale notes.
for note_file in "$notes_directory"/[0-9][0-9][0-9][0-9]-*.json; do
  [ -e "$note_file" ] || continue
  lesson_id="$(basename "$note_file" .json)"
  if ! jq -e --arg lesson_id "$lesson_id" '.lessons | has($lesson_id)' "$snapshot" > /dev/null; then
    rm -f -- "$note_file"
  fi
done

printf 'Saved full study export to %s\n' "$snapshot"
printf 'Generated per-lesson notes in %s\n' "$notes_directory"
